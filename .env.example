# .env.example 包含了必要的环境变量

LOG_LEVEL=info
DEPLOY_REGION=mainland

DATABASE_URL=postgresql://atypica:atypica@localhost:5432/atypica_dev
SHADOW_DATABASE_URL=postgresql://atypica:atypica@localhost:5432/atypica_dev_shadow

OPENAI_BASE_URL=
OPENAI_API_KEY=

AUTH_SECRET= # generate by `npx auth secret`
AUTH_TRUST_HOST="true" # required in productsion https://authjs.dev/getting-started/deployment#docker

CIPHER_PASSWORD="anything"

AWS_S3='
[{
  "origin": "",
  "bucketName": "",
  "region": "cn-north-1",
  "accessKeyId": "",
  "secretAccessKey": ""
}, {
  "origin": "",
  "bucketName": "",
  "region": "us-east-1",
  "accessKeyId": "",
  "secretAccessKey": ""
}]
'

# AWS Marketplace Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_MARKETPLACE_PRODUCT_CODE=
AWS_MARKETPLACE_SNS_TOPIC_ARN=
