# =============================================================================
# Core
# =============================================================================
DATABASE_URL=postgresql://atypica:atypica@localhost:5432/game_theory_dev
SHADOW_DATABASE_URL=postgresql://atypica:atypica@localhost:5432/game_theory_dev_shadow
AUTH_SECRET=your-nextauth-secret
CIPHER_PASSWORD=your-cipher-password
INTERNAL_API_SECRET=your-internal-api-secret

# =============================================================================
# Deployment
# =============================================================================
# DEPLOY_REGION=cn          # "cn" for mainland China routing, omit for global
# LOG_LEVEL=debug           # pino log level (default: info)

# =============================================================================
# AI Providers — set the ones you need
# =============================================================================

# OpenAI / Azure-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Vertex AI (option A: service account JSON, base64-encoded)
# GOOGLE_APPLICATION_CREDENTIALS_JSON_BASE64=
# GOOGLE_VERTEX_PROJECT=
# GOOGLE_VERTEX_LOCATION=us-central1

# Google Vertex AI (option B: individual fields)
# GOOGLE_VERTEX_PROJECT=
# GOOGLE_VERTEX_LOCATION=us-central1
# GOOGLE_VERTEX_CLIENT_EMAIL=
# GOOGLE_VERTEX_PRIVATE_KEY=

# Amazon Bedrock (uses AWS SDK default credential chain, or set explicitly)
# AWS_BEDROCK_ACCESS_KEY_ID=
# AWS_BEDROCK_SECRET_ACCESS_KEY=
# AWS_BEDROCK_REGION=us-east-1

# Azure OpenAI
# AZURE_API_KEY=
# AZURE_RESOURCE_NAME=

# XAI (Grok)
# XAI_API_KEY=

# =============================================================================
# Optional Services
# =============================================================================

# CDN proxy origin
# PROXY_CDN_ORIGIN=

# Meilisearch (persona search)
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_API_KEY=
# MEILISEARCH_MASTER_KEY=

# Email (Resend)
# RESEND_API_KEY=
# RESEND_FROM=noreply@example.com

# HTTPS proxy for outbound AI requests (China deployments)
# FETCH_HTTPS_PROXY=
