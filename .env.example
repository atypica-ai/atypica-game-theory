# Game Theory Lab — Required Environment Variables

LOG_LEVEL=info
DEPLOY_REGION=mainland

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://atypica:atypica@localhost:5432/game_theory_dev
SHADOW_DATABASE_URL=postgresql://atypica:atypica@localhost:5432/game_theory_dev_shadow

# Auth
AUTH_SECRET= # generate by `npx auth secret`
AUTH_TRUST_HOST="true" # required in production https://authjs.dev/getting-started/deployment#docker
CIPHER_PASSWORD="anything"

# LLM Providers (configure the ones you need)
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Meilisearch (for persona search)
MEILISEARCH_HOST=https://your-instance.meilisearch.io
MEILISEARCH_API_KEY=your-api-key-here
MEILISEARCH_MASTER_KEY=your-master-key-here
MEILISEARCH_INDEXES={"personas":"personas"}
