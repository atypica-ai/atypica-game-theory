// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // https://www.prisma.io/docs/orm/prisma-schema/overview/generators
  output          = "../src/prisma/client"
}

datasource db {
  provider          = "postgresql"
  // 开发环境:
  //  新增 extension 的这个 migration 执行前需要给一下 superuser 权限给数据库用户，搞完了以后再恢复回来
  //  ALTER USER username WITH SUPERUSER; ALTER USER username WITH NOSUPERUSER;
  // 生产环境:
  //  不给用户 superuser 权限
  //  先用用 superuser 运行 CREATE EXTENSION VECTOR; 然后直接 migrate deploy，因为 extension 已经创建，会跳过
  extensions        = [vector]
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String    @default("") @db.VarChar(64)
  email         String    @unique
  password      String
  emailVerified DateTime? @db.Timestamptz(6)
  lastLogin     Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  tokens            UserTokens?
  tokensLogs        UserTokensLog[]
  adminUser         AdminUser?
  analysts          Analyst[]
  userChats         UserChat[]
  paymentRecords    PaymentRecord[]
  subscriptions     UserSubscription[]
  interviewProjects InterviewProject[]
}

enum AdminRole {
  SUPER_ADMIN
  REGULAR_ADMIN
}

model AdminUser {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique
  user        User      @relation(fields: [userId], references: [id])
  role        AdminRole @default(REGULAR_ADMIN)
  permissions Json

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model VerificationCode {
  id    Int    @id @default(autoincrement())
  email String
  code  String @db.VarChar(16)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  expiresAt DateTime? @db.Timestamptz(6)
}

model InvitationCode {
  id        Int     @id @default(autoincrement())
  code      String  @unique @db.VarChar(16)
  usedBy    String?
  createdBy String?

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  usedAt    DateTime? @db.Timestamptz(6)
}

model Persona {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(255)
  source          String    @db.VarChar(255)
  tags            Json // 存储标签数组
  samples         Json // 存储小红书用户主页链接作为参考样本
  prompt          String    @db.Text
  scoutUserChatId Int?      @db.Integer
  scoutUserChat   UserChat? @relation(fields: [scoutUserChatId], references: [id])
  locale          String?   @db.VarChar(16)

  embedding Unsupported("vector(1024)")? // 使用 Unsupported 类型表示向量

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  interviews AnalystInterview[]

  @@index([embedding])
}

model Analyst {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id])
  brief           String    @db.Text
  role            String    @db.VarChar(255)
  topic           String    @db.Text
  studySummary    String    @db.Text
  studyUserChatId Int?      @unique @db.Integer
  studyUserChat   UserChat? @relation(fields: [studyUserChatId], references: [id])
  attachments     Json?
  locale          String?   @db.VarChar(16)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  interviews    AnalystInterview[]
  reports       AnalystReport[]
  featuredStudy FeaturedStudy?
}

model FeaturedStudy {
  id              Int      @id @default(autoincrement())
  analystId       Int      @unique
  analyst         Analyst  @relation(fields: [analystId], references: [id])
  studyUserChatId Int      @unique @db.Integer
  studyUserChat   UserChat @relation(fields: [studyUserChatId], references: [id])
  displayOrder    Int      @default(0)
  category        String?  @db.VarChar(64)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model AnalystReport {
  id          Int       @id @default(autoincrement())
  token       String    @unique @db.VarChar(64)
  analystId   Int       @db.Integer
  analyst     Analyst   @relation(fields: [analystId], references: [id])
  instruction String    @db.Text
  coverSvg    String    @db.Text
  onePageHtml String    @db.Text
  generatedAt DateTime? @db.Timestamptz(6)
  extra       Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model AnalystInterview {
  id                  Int       @id @default(autoincrement())
  analystId           Int       @db.Integer
  analyst             Analyst   @relation(fields: [analystId], references: [id])
  personaId           Int       @db.Integer
  persona             Persona   @relation(fields: [personaId], references: [id])
  instruction         String    @db.Text
  conclusion          String    @db.Text
  interviewUserChatId Int?      @unique @db.Integer
  interviewUserChat   UserChat? @relation(fields: [interviewUserChatId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([analystId, personaId])
}

enum UserChatKind {
  scout
  study
  interview
  interviewSession
  misc
}

model UserChat {
  id              Int          @id @default(autoincrement())
  token           String       @unique @db.VarChar(64)
  userId          Int
  user            User         @relation(fields: [userId], references: [id])
  title           String       @db.VarChar(255)
  kind            UserChatKind
  backgroundToken String?      @db.VarChar(255)
  extra           Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  personas         Persona[]
  analyst          Analyst?
  analystInterview AnalystInterview?
  featuredStudy    FeaturedStudy?
  statistics       ChatStatistics[]
  messages         ChatMessage[]
  interviewSession InterviewSession?
}

enum MessageRole {
  system
  user
  assistant
  data
}

model ChatMessage {
  id          Int         @id @default(autoincrement())
  messageId   String      @unique @db.VarChar(64)
  userChatId  Int
  userChat    UserChat    @relation(fields: [userChatId], references: [id])
  role        MessageRole
  content     String      @db.Text
  parts       Json
  extra       Json?
  attachments Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([userChatId, id]) // 通过自增 ID 排序
}

enum ChatStatisticsDimension {
  tokens
  duration
  steps
  personas
  interviews
}

model ChatStatistics {
  id         Int                     @id @default(autoincrement())
  userChatId Int
  userChat   UserChat                @relation(fields: [userChatId], references: [id])
  dimension  ChatStatisticsDimension
  value      Int                     @default(0)
  extra      Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([userChatId, dimension])
}

enum PaymentStatus {
  pending
  succeeded
  failed
}

enum Currency {
  CNY
  USD
}

model PaymentRecord {
  id            Int           @id @default(autoincrement())
  userId        Int
  user          User          @relation(fields: [userId], references: [id])
  orderNo       String        @unique @db.VarChar(64)
  amount        Float
  currency      Currency
  status        PaymentStatus
  paymentMethod String        @db.VarChar(64)
  charge        Json
  chargeId      String        @unique @db.VarChar(255)
  credential    Json
  description   String        @db.VarChar(255)
  paidAt        DateTime?     @db.Timestamptz(6)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  paymentLines PaymentLine[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(64)
  price       Float
  description String   @db.VarChar(255)
  currency    Currency
  extra       Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  paymentLines PaymentLine[]

  @@unique([name, currency])
}

model PaymentLine {
  id              Int           @id @default(autoincrement())
  paymentRecordId Int
  paymentRecord   PaymentRecord @relation(fields: [paymentRecordId], references: [id])
  productId       Int
  product         Product       @relation(fields: [productId], references: [id])
  productName     String        @db.VarChar(64)
  description     String        @db.VarChar(255)
  quantity        Int
  price           Float
  currency        Currency      @default(CNY)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([paymentRecordId, productId])
}

enum SubscriptionPlan {
  pro
}

model UserSubscription {
  id       Int              @id @default(autoincrement())
  userId   Int
  user     User             @relation(fields: [userId], references: [id])
  plan     SubscriptionPlan
  startsAt DateTime         @db.Timestamptz(6)
  endsAt   DateTime         @db.Timestamptz(6)
  extra    Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model UserTokens {
  id      Int  @id @default(autoincrement())
  userId  Int  @unique
  user    User @relation(fields: [userId], references: [id])
  balance Int  @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

enum UserTokensLogVerb {
  recharge
  consume
  subscription
  gift
  signup
}

enum UserTokensLogResourceType {
  StudyUserChat
  ScoutUserChat // 没用到
  InterviewProject
  PaymentRecord
}

model UserTokensLog {
  id           Int                        @id @default(autoincrement())
  userId       Int
  user         User                       @relation(fields: [userId], references: [id])
  value        Int
  verb         UserTokensLogVerb
  resourceType UserTokensLogResourceType?
  resourceId   Int?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([userId, verb])
  @@index([userId, verb, resourceType, resourceId])
}

model SystemConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(255)
  value Json

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model InterviewProject {
  id            Int      @id @default(autoincrement())
  token         String   @unique
  userId        Int
  title         String   @db.VarChar(255)
  category      String   @db.VarChar(64)
  brief         String?  @db.Text
  objectives    String[]
  digest        String?  @db.Text
  collectSystem String?  @db.Text // 访谈真人过程中的系统提示词

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions InterviewSession[]
}

enum InterviewSessionKind {
  clarify // Internal - helps clarify your needs/requirements
  collect // External - collects data from outside sources
}

enum InterviewSessionStatus {
  pending
  active
  completed
}

model InterviewSession {
  id          Int                    @id @default(autoincrement())
  token       String                 @unique
  projectId   Int
  userChatId  Int?                   @unique
  title       String                 @db.VarChar(255)
  notes       String?                @db.VarChar(255) // 备注信息
  kind        InterviewSessionKind
  status      InterviewSessionStatus
  summary     String?                @db.Text
  keyInsights String[]
  analysis    String?                @db.Text
  expiresAt   DateTime?              @db.Timestamptz(6)
  completedAt DateTime?              @db.Timestamptz(6)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  project  InterviewProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userChat UserChat?        @relation(fields: [userChatId], references: [id])
}

model ImageGeneration {
  id          Int       @id @default(autoincrement())
  prompt      String    @db.Text
  promptHash  String    @unique // unique hash
  objectUrl   String    @db.VarChar(255) // s3 object url for generated image
  extra       Json?
  generatedAt DateTime? @db.Timestamptz(6)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}
