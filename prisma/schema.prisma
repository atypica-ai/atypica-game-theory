// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client"
  previewFeatures = ["postgresqlExtensions"]
  // https://www.prisma.io/docs/orm/prisma-schema/overview/generators
  output          = "../src/prisma/generated"
}

datasource db {
  provider   = "postgresql"
  // 开发环境:
  //  新增 extension 的这个 migration 执行前需要给一下 superuser 权限给数据库用户，搞完了以后再恢复回来
  //  ALTER USER username WITH SUPERUSER; ALTER USER username WITH NOSUPERUSER;
  // 生产环境:
  //  不给用户 superuser 权限
  //  先用用 superuser 运行 CREATE EXTENSION VECTOR; 然后直接 migrate deploy，因为 extension 已经创建，会跳过
  extensions = [vector]
  // url               = env("DATABASE_URL")
  // shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model ApiKey {
  id     Int    @id @default(autoincrement())
  key    String @unique @db.VarChar(128) // atypica_{64 hex chars}
  // userId and teamId are mutually exclusive (but each user/team can have multiple keys)
  userId Int?
  user   User?  @relation("UserApiKey", fields: [userId], references: [id], onDelete: Cascade)
  teamId Int?
  team   Team?  @relation("TeamApiKey", fields: [teamId], references: [id], onDelete: Cascade)
  extra  Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model TeamConfig {
  id     Int    @id @default(autoincrement())
  teamId Int
  team   Team   @relation("TeamConfig", fields: [teamId], references: [id], onDelete: Cascade)
  key    String @db.VarChar(255)
  value  Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([teamId, key])
}

model Team {
  id          Int    @id @default(autoincrement())
  name        String @db.VarChar(255)
  seats       Int
  ownerUserId Int
  ownerUser   User   @relation("TeamOwner", fields: [ownerUserId], references: [id])
  members     User[] @relation("TeamMembership")
  extra       Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  tokensAccount     TokensAccount?
  tokensLogs        TokensLog[]
  subscriptions     Subscription[]
  teamConfigs       TeamConfig[]       @relation("TeamConfig")
  apiKeys           ApiKey[]           @relation("TeamApiKey")
  memories          Memory[]           @relation("TeamMemory")
  researchTemplates ResearchTemplate[] @relation("TeamResearchTemplates")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String    @default("") @db.VarChar(64)
  email         String?   @unique // required for personal user
  password      String
  emailVerified DateTime? @db.Timestamptz(6)

  // teams owned by the user
  teamsAsOwner      Team[] @relation("TeamOwner")
  // If this is a team user, points to the team, required for team user, null for personal user
  teamIdAsMember    Int?
  teamAsMember      Team?  @relation("TeamMembership", fields: [teamIdAsMember], references: [id])
  // If this is a team user, points to the corresponding personal user
  personalUserId    Int?
  personalUser      User?  @relation("PersonalToTeamMember", fields: [personalUserId], references: [id])
  teamUsersAsMember User[] @relation("PersonalToTeamMember") // List of team users created by the personal user

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // as resource owner
  profile           UserProfile?
  adminUser         AdminUser?
  tokensAccount     TokensAccount?
  tokensLogs        TokensLog[]
  analysts          Analyst[]
  userChats         UserChat[]
  paymentRecords    PaymentRecord[]
  subscriptions     Subscription[]
  attachmentFiles   AttachmentFile[]
  personaImports    PersonaImport[]
  interviewProjects InterviewProject[]
  sages             Sage[]
  sageChats         SageChat[]
  apiKeys           ApiKey[]           @relation("UserApiKey")
  memories          Memory[]           @relation("UserMemory")
  researchTemplates ResearchTemplate[] @relation("UserResearchTemplates")
  agentSkills       AgentSkill[]       @relation("UserAgentSkills")
  analystPodcasts   AnalystPodcast[]
  analystReports    AnalystReport[]

  // relations
  userPersonaChatRelations       UserPersonaChatRelation[]
  interviewSessionsAsInterviewee InterviewSession[]
  awsMarketplaceCustomer         AWSMarketplaceCustomer?

  // 唯一定位一个 personal user 在一个 team 里对应的 team member 身份
  @@unique([teamIdAsMember, personalUserId])
}

model UserProfile {
  id         Int  @id @default(autoincrement())
  userId     Int  @unique
  user       User @relation(fields: [userId], references: [id])
  lastLogin  Json @default("{}")
  onboarding Json @default("{}")
  extra      Json @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

enum AdminRole {
  SUPER_ADMIN
  REGULAR_ADMIN
}

model AdminUser {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique
  user        User      @relation(fields: [userId], references: [id])
  role        AdminRole @default(REGULAR_ADMIN)
  permissions Json      @default("[]")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model VerificationCode {
  id    Int    @id @default(autoincrement())
  email String
  code  String @db.VarChar(16)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  expiresAt DateTime? @db.Timestamptz(6)
}

model AgentSkill {
  id          Int    @id @default(autoincrement())
  userId      Int
  user        User   @relation("UserAgentSkills", fields: [userId], references: [id], onDelete: Cascade)
  name        String @db.VarChar(255)
  description String @db.Text
  objectUrl   String @db.VarChar(255)
  extra       Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([userId, name])
}

model Persona {
  id              Int            @id @default(autoincrement())
  token           String         @unique @db.VarChar(64)
  name            String         @db.VarChar(255)
  source          String         @db.VarChar(255)
  tags            Json           @default("[]") // 存储标签数组
  samples         Json           @default("[]") // 存储小红书用户主页链接作为参考样本
  prompt          String         @db.Text
  locale          String?        @db.VarChar(16)
  tier            Int            @default(0) @db.Integer
  extra           Json           @default("{}")
  scoutUserChatId Int?           @db.Integer
  scoutUserChat   UserChat?      @relation(fields: [scoutUserChatId], references: [id]) // 是否需要 onDelete: SetNull ?
  personaImportId Int?           @db.Integer
  personaImport   PersonaImport? @relation(fields: [personaImportId], references: [id]) // 是否需要 onDelete: SetNull ?

  embedding Unsupported("halfvec(1024)")? // 使用 Unsupported 类型表示向量

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  interviews               AnalystInterview[]
  userPersonaChatRelations UserPersonaChatRelation[]

  interviewSessionsAsInterviewee InterviewSession[]

  @@index([embedding])
  @@index([tier, locale])
}

model Analyst {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id])
  brief           String    @db.Text
  role            String    @db.VarChar(255)
  topic           String    @db.Text
  studySummary    String    @db.Text // 目前已经用不到了
  studyLog        String    @default("") @db.Text
  studyUserChatId Int?      @unique @db.Integer
  studyUserChat   UserChat? @relation(fields: [studyUserChatId], references: [id])
  attachments     Json      @default("[]")
  kind            String?   @db.VarChar(16)
  locale          String?   @db.VarChar(16)
  extra           Json      @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([userId])
}

model FeaturedItem {
  id           Int    @id @default(autoincrement())
  resourceType String @db.VarChar(50)
  resourceId   Int
  locale       String @db.VarChar(16)
  extra        Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([resourceType, resourceId])
}

model AnalystReport {
  id          Int       @id @default(autoincrement())
  token       String    @unique @db.VarChar(64)
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  instruction String    @db.Text
  coverSvg    String    @db.Text
  onePageHtml String    @db.Text
  generatedAt DateTime? @db.Timestamptz(6)
  extra       Json      @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  analystId Int? @db.Integer // legacy field, remove after 2.15
}

model AnalystPodcast {
  id          Int       @id @default(autoincrement())
  token       String    @unique @db.VarChar(64)
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  instruction String    @db.Text
  script      String    @db.Text
  objectUrl   String?   @db.VarChar(255)
  generatedAt DateTime? @db.Timestamptz(6)
  extra       Json      @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  analystId Int? @db.Integer // legacy field, remove after 2.15
}

enum UserChatKind {
  scout
  study
  interview
  interviewSession
  sageSession
  universal
  misc
}

model UserChat {
  id              Int          @id @default(autoincrement())
  token           String       @unique @db.VarChar(64)
  userId          Int
  user            User         @relation(fields: [userId], references: [id])
  title           String       @db.VarChar(255)
  kind            UserChatKind
  backgroundToken String?      @db.VarChar(255)
  context         Json         @default("{}")
  extra           Json         @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  personas                Persona[]
  analyst                 Analyst?
  analystInterview        AnalystInterview?
  statistics              ChatStatistics[]
  messages                ChatMessage[]
  personaImport           PersonaImport?
  userPersonaChatRelation UserPersonaChatRelation?
  interviewSession        InterviewSession?
  sageChat                SageChat?
  sageInterview           SageInterview?

  @@index([userId])
}

enum MessageRole {
  system
  user
  assistant
  data
}

model ChatMessage {
  id          Int         @id @default(autoincrement())
  messageId   String      @unique @db.VarChar(64)
  userChatId  Int
  userChat    UserChat    @relation(fields: [userChatId], references: [id])
  role        MessageRole
  content     String      @db.Text
  parts       Json        @default("[]")
  extra       Json        @default("{}")
  attachments Json        @default("[]")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([userChatId, id]) // 通过自增 ID 排序
}

enum ChatStatisticsDimension {
  tokens
  duration
  steps
  personas
  interviews
}

model ChatStatistics {
  id         Int                     @id @default(autoincrement())
  userChatId Int
  userChat   UserChat                @relation(fields: [userChatId], references: [id])
  dimension  ChatStatisticsDimension
  value      Int                     @default(0)
  extra      Json                    @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([userChatId, dimension])
}

model Product {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(64)
  price         Float
  description   String   @db.VarChar(255)
  currency      Currency
  stripePriceId String?  @db.VarChar(50)
  extra         Json     @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  paymentLines PaymentLine[]

  @@unique([name, currency])
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

enum Currency {
  CNY
  USD
}

model PaymentRecord {
  id            Int           @id @default(autoincrement())
  userId        Int
  user          User          @relation(fields: [userId], references: [id])
  orderNo       String        @unique @db.VarChar(64)
  amount        Float
  currency      Currency
  status        PaymentStatus
  paymentMethod String        @db.VarChar(64)
  description   String        @db.VarChar(255)
  paidAt        DateTime?     @db.Timestamptz(6)

  // pingxx
  pingxxCharge     Json    @default("{}") // ping++ charge or stripe invoice
  pingxxChargeId   String? @unique @db.VarChar(255) // ping++ chargeId or stripe invoiceId
  pingxxCredential Json    @default("{}") // for ping++ payment intent creation

  // stripe
  stripeInvoice   Json    @default("{}")
  stripeInvoiceId String? @unique @db.VarChar(50)
  stripeSession   Json    @default("{}") // for stripe payment intent creation

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  paymentLines PaymentLine[]
  subscription Subscription?

  @@index([userId])
}

model PaymentLine {
  id              Int           @id @default(autoincrement())
  paymentRecordId Int
  paymentRecord   PaymentRecord @relation(fields: [paymentRecordId], references: [id])
  productId       Int
  product         Product       @relation(fields: [productId], references: [id])
  productName     String        @db.VarChar(64)
  description     String        @db.VarChar(255)
  quantity        Int
  price           Float
  currency        Currency      @default(CNY)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([paymentRecordId, productId])
  @@unique([paymentRecordId, productName])
}

enum SubscriptionPlan {
  pro
  max
  super
  team
  superteam
}

model Subscription {
  id       Int              @id @default(autoincrement())
  userId   Int?
  user     User?            @relation(fields: [userId], references: [id])
  teamId   Int?
  team     Team?            @relation(fields: [teamId], references: [id])
  plan     SubscriptionPlan
  startsAt DateTime         @db.Timestamptz(6)
  endsAt   DateTime         @db.Timestamptz(6)
  extra    Json             @default("{}")

  paymentRecordId      Int?           @unique //一个支付记录只能生成一条 Subscription
  paymentRecord        PaymentRecord? @relation(fields: [paymentRecordId], references: [id])
  stripeSubscriptionId String?        @db.VarChar(50)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  activeTokensAccount TokensAccount?

  @@index([userId])
  @@index([teamId])
}

model TokensAccount {
  id               Int       @id @default(autoincrement())
  userId           Int?      @unique
  user             User?     @relation(fields: [userId], references: [id])
  teamId           Int?      @unique
  team             Team?     @relation(fields: [teamId], references: [id])
  permanentBalance Int       @default(0)
  monthlyBalance   Int       @default(0)
  monthlyResetAt   DateTime? @db.Timestamptz(6)
  extra            Json      @default("{}")

  activeSubscriptionId Int?          @unique
  activeSubscription   Subscription? @relation(fields: [activeSubscriptionId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

enum TokensLogVerb {
  recharge
  consume
  subscription
  subscriptionReset
  gift
  signup
}

model TokensLog {
  id           Int           @id @default(autoincrement())
  userId       Int?
  user         User?         @relation(fields: [userId], references: [id])
  teamId       Int?
  team         Team?         @relation(fields: [teamId], references: [id])
  value        Int
  verb         TokensLogVerb
  resourceType String?       @db.VarChar(50)
  resourceId   Int?
  extra        Json          @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([userId, verb, resourceType, resourceId])
  @@index([teamId, verb, resourceType, resourceId])
}

model SystemConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(255)
  value Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model ImageGeneration {
  id          Int       @id @default(autoincrement())
  prompt      String    @db.Text
  promptHash  String    @unique // unique hash
  objectUrl   String    @db.VarChar(255) // s3 object url for generated image
  extra       Json      @default("{}")
  generatedAt DateTime? @db.Timestamptz(6)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model AttachmentFile {
  id        Int    @id @default(autoincrement())
  userId    Int
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String @db.VarChar(255)
  mimeType  String @db.VarChar(255)
  size      Int
  objectUrl String @unique @db.VarChar(255) // s3 object url
  extra     Json   @default("{}") // not useful for the moment

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model PersonaImport {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id])
  attachments     Json      @default("[]")
  context         String    @default("") @db.Text // parse attachments as context
  analysis        Json      @default("{}")
  extra           Json      @default("{}")
  extraUserChatId Int?      @unique // interview UserChat for follow up questions
  extraUserChat   UserChat? @relation(fields: [extraUserChatId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  personas Persona[]
}

model UserPersonaChatRelation {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  personaId  Int
  persona    Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  userChatId Int      @unique
  userChat   UserChat @relation(fields: [userChatId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([userId, personaId])
}

model InterviewProject {
  id        Int    @id @default(autoincrement())
  token     String @unique
  userId    Int
  user      User   @relation(fields: [userId], references: [id])
  brief     String @db.Text
  questions Json   @default("[]")
  extra     Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  sessions InterviewSession[]
  reports  InterviewReport[]
}

model InterviewSession {
  id                   Int              @id @default(autoincrement())
  title                String           @default("") @db.Text
  projectId            Int
  project              InterviewProject @relation(fields: [projectId], references: [id])
  userChatId           Int?             @unique
  userChat             UserChat?        @relation(fields: [userChatId], references: [id])
  intervieweeUserId    Int? // 受访的真人用户
  intervieweeUser      User?            @relation(fields: [intervieweeUserId], references: [id], onDelete: SetNull)
  intervieweePersonaId Int? // 受访的 AI 角色
  intervieweePersona   Persona?         @relation(fields: [intervieweePersonaId], references: [id], onDelete: SetNull)
  extra                Json             @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model InterviewReport {
  id          Int              @id @default(autoincrement())
  token       String           @unique @db.VarChar(64)
  projectId   Int              @db.Integer
  project     InterviewProject @relation(fields: [projectId], references: [id])
  onePageHtml String           @db.Text
  generatedAt DateTime?        @db.Timestamptz(6)
  extra       Json             @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model PersonaPanel {
  id          Int    @id @default(autoincrement())
  userId      Int
  personaIds  Json   @default("[]") // Persona ID 列表
  title       String @default("") @db.VarChar(255)
  instruction String @default("") @db.Text // 用户指令
  extra       Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  discussionTimelines DiscussionTimeline[]
  analystInterviews   AnalystInterview[]

  @@index([userId])
}

model AnalystInterview {
  id                  Int           @id @default(autoincrement())
  personaPanelId      Int?
  personaPanel        PersonaPanel? @relation(fields: [personaPanelId], references: [id], onDelete: SetNull)
  personaId           Int           @db.Integer
  persona             Persona       @relation(fields: [personaId], references: [id])
  instruction         String        @db.Text
  conclusion          String        @db.Text
  interviewUserChatId Int?          @unique @db.Integer
  interviewUserChat   UserChat?     @relation(fields: [interviewUserChatId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  analystId Int? @db.Integer // legacy field, remove after 2.15

  @@index([personaPanelId])
}

model DiscussionTimeline {
  id             Int           @id @default(autoincrement())
  token          String        @unique @db.VarChar(64)
  personaPanelId Int?
  personaPanel   PersonaPanel? @relation(fields: [personaPanelId], references: [id], onDelete: SetNull)
  instruction    String        @db.Text // 用户指令
  events         Json          @default("[]") // TimelineEvent[] 数组
  summary        String        @db.Text // 主持人最终总结 default empty string
  minutes        String        @db.Text // 结构化讨论纪要（无损记录）default empty string
  extra          Json          @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([personaPanelId])
}

// ===== Sage (Expert Agent) System =====

model Sage {
  id        Int    @id @default(autoincrement())
  token     String @unique @db.VarChar(64)
  userId    Int
  user      User   @relation(fields: [userId], references: [id])
  name      String @db.VarChar(255)
  domain    String @db.VarChar(255)
  expertise Json   @default("[]")
  avatar    Json   @default("{}")
  bio       String @db.Text
  locale    String @db.VarChar(16)
  extra     Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  chats           SageChat[]
  interviews      SageInterview[]
  sources         SageSource[]
  knowledgeGaps   SageKnowledgeGap[]
  memoryDocuments SageMemoryDocument[]
}

model SageSource {
  id            Int    @id @default(autoincrement())
  sageId        Int
  sage          Sage   @relation(fields: [sageId], references: [id], onDelete: Cascade)
  content       Json // { type:"text", text } or { type:"file", objectUrl, name, mimeType, size } or { type:"url", url }
  title         String @db.VarChar(255)
  extractedText String @db.Text
  extra         Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model SageChat {
  id         Int      @id @default(autoincrement())
  sageId     Int
  sage       Sage     @relation(fields: [sageId], references: [id], onDelete: Cascade)
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  userChatId Int      @unique
  userChat   UserChat @relation(fields: [userChatId], references: [id])
  extra      Json     @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model SageInterview {
  id         Int      @id @default(autoincrement())
  sageId     Int
  sage       Sage     @relation(fields: [sageId], references: [id], onDelete: Cascade)
  userChatId Int      @unique
  userChat   UserChat @relation(fields: [userChatId], references: [id])
  extra      Json     @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model SageKnowledgeGap {
  id          Int       @id @default(autoincrement())
  sageId      Int
  sage        Sage      @relation(fields: [sageId], references: [id], onDelete: Cascade)
  area        String    @db.VarChar(255)
  description String    @db.Text
  severity    String    @db.VarChar(32)
  impact      String    @db.Text
  resolvedAt  DateTime? @db.Timestamptz(6)
  // extra 包含:
  // - sourceChat: { id: number, token: string } - 来源对话(UserChat.id+token,用于UI跳转)
  // - resolvedChat: { id: number, token: string } - 解决访谈(UserChat.id+token,用于UI跳转)
  extra       Json      @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model SageMemoryDocument {
  id      Int  @id @default(autoincrement())
  sageId  Int
  sage    Sage @relation(fields: [sageId], references: [id], onDelete: Cascade)
  version Int

  core    String @default("") @db.Text // 核心记忆 (Markdown)
  working Json   @default("[]") // 工作记忆 (来自访谈的待整合知识)

  changeNotes String @db.Text
  extra       Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([sageId, version])
  @@index([sageId, version(sort: Desc)]) // Optimize for getting latest version
}

model Memory {
  id      Int   @id @default(autoincrement())
  // userId and teamId are mutually exclusive (but each user/team can have multiple versions)
  userId  Int?
  user    User? @relation("UserMemory", fields: [userId], references: [id], onDelete: Cascade)
  teamId  Int?
  team    Team? @relation("TeamMemory", fields: [teamId], references: [id], onDelete: Cascade)
  version Int

  core    String @default("") @db.Text // 核心记忆 (Markdown)
  working Json   @default("[]") // 工作记忆 (来自对话的待整合知识)

  changeNotes String @db.Text
  extra       Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([userId, version])
  @@unique([teamId, version])
  @@index([userId, version(sort: Desc)]) // Optimize for getting latest version
  @@index([teamId, version(sort: Desc)]) // Optimize for getting latest version
}

model BlogArticle {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  content     String    @db.Text
  slug        String    @db.VarChar(255)
  publishedAt DateTime? @db.Timestamptz(6)
  locale      String    @db.VarChar(16)
  extra       Json      @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([locale, slug])
  @@index([locale, publishedAt])
}

model ResearchTemplate {
  id Int @id @default(autoincrement())

  // 核心字段
  title       String @db.VarChar(255)
  description String @db.Text
  locale      String @db.VarChar(16)

  // 所有权（null = 公共模板，非 null = 个人/团队模板）
  userId Int?
  user   User? @relation("UserResearchTemplates", fields: [userId], references: [id], onDelete: Cascade)
  teamId Int?
  team   Team? @relation("TeamResearchTemplates", fields: [teamId], references: [id], onDelete: Cascade)

  // 扩展字段（tags, category, useCount 等）
  extra Json @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([locale, userId])
  @@index([locale, teamId])
}

// ===== AWS Marketplace Integration =====

model AWSMarketplaceCustomer {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // AWS customer identifiers
  customerIdentifier String @unique @db.VarChar(255) // AWS customer ID
  productCode        String @db.VarChar(255) // AWS product code

  // Subscription status
  status String @default("pending") // pending, active, cancelled, expired

  // Subscription details
  dimension String? @db.VarChar(64) // Subscription dimension/plan (e.g., "team_plan")
  quantity  Int? // Number of allowed users (e.g., 3)

  // Time information
  subscribedAt DateTime? @db.Timestamptz(6)
  expiresAt    DateTime? @db.Timestamptz(6)
  cancelledAt  DateTime? @db.Timestamptz(6)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  events AWSMarketplaceEvent[]

  @@index([customerIdentifier])
  @@index([userId])
}

model AWSMarketplaceEvent {
  id         Int                    @id @default(autoincrement())
  customerId Int
  customer   AWSMarketplaceCustomer @relation(fields: [customerId], references: [id])

  eventType String @db.VarChar(64) // subscribe-success, unsubscribe-success, etc.
  eventData Json   @default("{}") // Complete SNS message

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([customerId])
  @@index([eventType])
}
