// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  previewFeatures = ["postgresqlExtensions"]
  // https://www.prisma.io/docs/orm/prisma-schema/overview/generators
  output          = "../src/prisma/generated"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider   = "postgresql"
  // 开发环境:
  //  新增 extension 的这个 migration 执行前需要给一下 superuser 权限给数据库用户，搞完了以后再恢复回来
  //  ALTER USER username WITH SUPERUSER; ALTER USER username WITH NOSUPERUSER;
  // 生产环境:
  //  不给用户 superuser 权限
  //  先用用 superuser 运行 CREATE EXTENSION VECTOR; 然后直接 migrate deploy，因为 extension 已经创建，会跳过
  extensions = [vector]
  // url               = env("DATABASE_URL")
  // shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Team {
  id          Int    @id @default(autoincrement())
  name        String @db.VarChar(255)
  seats       Int
  ownerUserId Int
  ownerUser   User   @relation("TeamOwner", fields: [ownerUserId], references: [id])
  members     User[] @relation("TeamMembership")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  personas Persona[]
}

model User {
  id            Int       @id @default(autoincrement())
  name          String    @default("") @db.VarChar(64)
  email         String?   @unique // required for personal user
  password      String
  emailVerified DateTime? @db.Timestamptz(6)

  // teams owned by the user
  teamsAsOwner Team[] @relation("TeamOwner")
  // If this is a team user, points to the team, required for team user, null for personal user
  teamIdAsMember Int?
  teamAsMember   Team? @relation("TeamMembership", fields: [teamIdAsMember], references: [id])
  // If this is a team user, points to the corresponding personal user
  personalUserId    Int?
  personalUser      User?  @relation("PersonalToTeamMember", fields: [personalUserId], references: [id])
  teamUsersAsMember User[] @relation("PersonalToTeamMember") // List of team users created by the personal user

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  profile  UserProfile?
  personas Persona[]

  // 唯一定位一个 personal user 在一个 team 里对应的 team member 身份
  @@unique([teamIdAsMember, personalUserId])
}

model UserProfile {
  id        Int  @id @default(autoincrement())
  userId    Int  @unique
  user      User @relation(fields: [userId], references: [id], onDelete: Restrict)
  /// [UserLastLogin]
  lastLogin Json @default("{}")
  /// [UserProfileExtra]
  extra     Json @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model VerificationCode {
  id        Int      @id @default(autoincrement())
  email     String   @db.VarChar(255)
  code      String   @db.VarChar(6)
  expiresAt DateTime @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([email, code])
  @@index([expiresAt])
}

model Persona {
  id     Int    @id @default(autoincrement())
  token  String @unique @db.VarChar(64)
  userId Int?
  user   User?  @relation(fields: [userId], references: [id], onDelete: Restrict)
  teamId Int?
  team   Team?  @relation(fields: [teamId], references: [id], onDelete: Restrict)
  name   String @db.VarChar(255)
  source String @db.VarChar(255)
  /// [string[]]
  tags    Json @default("[]") // 存储标签数组
  /// [string[]]
  samples Json @default("[]") // 存储小红书用户主页链接作为参考样本
  prompt  String @db.Text
  /// [Locale]
  locale String? @db.VarChar(16)
  /// ![0|1|2|3]
  tier Int @default(0) @db.Integer
  /// [PersonaExtra]
  extra Json @default("{}")

  embedding Unsupported("halfvec(1024)")? // 使用 Unsupported 类型表示向量

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([embedding])
  @@index([tier, locale])
  @@index([userId])
}

model GameSession {
  id         Int    @id @default(autoincrement())
  token      String @unique @db.VarChar(64)
  gameType   String @db.VarChar(64)
  personaIds Json   @default("[]")
  /// [GameSessionTimeline]
  timeline Json   @default("{}")
  status   String @default("pending") @db.VarChar(32)
  extra    Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model Tournament {
  id         Int    @id @default(autoincrement())
  token      String @unique @db.VarChar(64)
  personaIds Json   @default("[]")
  /// [TournamentState]
  state  Json   @default("{}")
  status String @default("pending") @db.VarChar(32)
  extra  Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}
