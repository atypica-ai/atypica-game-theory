// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  emailVerified DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userAnalysts   UserAnalyst[]
  userChats      UserChat[]
  paymentRecords PaymentRecord[]
  tokens         UserTokens?
  tokensLogs     UserTokensLog[]
  adminUser      AdminUser?
}

enum AdminRole {
  SUPER_ADMIN
  REGULAR_ADMIN
}

model AdminUser {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique
  user        User      @relation(fields: [userId], references: [id])
  role        AdminRole @default(REGULAR_ADMIN)
  permissions Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationCode {
  id    Int    @id @default(autoincrement())
  email String
  code  String @db.VarChar(16)

  createdAt DateTime  @default(now())
  expiresAt DateTime?
}

model InvitationCode {
  id        Int     @id @default(autoincrement())
  code      String  @unique @db.VarChar(16)
  usedBy    String?
  createdBy String?

  createdAt DateTime  @default(now())
  usedAt    DateTime?
}

model Persona {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(255)
  source          String    @db.VarChar(255)
  tags            Json // 存储标签数组
  samples         Json // 存储小红书用户主页链接作为参考样本
  prompt          String    @db.Text
  scoutUserChatId Int?      @db.Int
  scoutUserChat   UserChat? @relation(fields: [scoutUserChatId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interviews AnalystInterview[]
}

model Analyst {
  id              Int       @id @default(autoincrement())
  role            String    @db.VarChar(255)
  topic           String    @db.Text
  studySummary    String    @db.Text
  studyUserChatId Int?      @unique @db.Int
  studyUserChat   UserChat? @relation(fields: [studyUserChatId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interviews    AnalystInterview[]
  userAnalysts  UserAnalyst[]
  reports       AnalystReport[]
  featuredStudy FeaturedStudy?
}

model FeaturedStudy {
  id              Int      @id @default(autoincrement())
  analystId       Int      @unique
  analyst         Analyst  @relation(fields: [analystId], references: [id])
  studyUserChatId Int      @unique @db.Int
  studyUserChat   UserChat @relation(fields: [studyUserChatId], references: [id])
  displayOrder    Int      @default(0)
  category        String?  @db.VarChar(64)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnalystReport {
  id          Int       @id @default(autoincrement())
  token       String    @unique @db.VarChar(64)
  analystId   Int       @db.Int
  analyst     Analyst   @relation(fields: [analystId], references: [id])
  coverSvg    String    @db.Text
  onePageHtml String    @db.LongText
  generatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnalystInterview {
  id                  Int       @id @default(autoincrement())
  analystId           Int       @db.Int
  analyst             Analyst   @relation(fields: [analystId], references: [id])
  personaId           Int       @db.Int
  persona             Persona   @relation(fields: [personaId], references: [id])
  personaPrompt       String    @db.Text
  interviewerPrompt   String    @db.Text
  conclusion          String    @db.Text
  interviewUserChatId Int?      @unique @db.Int
  interviewUserChat   UserChat? @relation(fields: [interviewUserChatId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([analystId, personaId])
}

model UserAnalyst {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id])
  analystId Int
  analyst   Analyst @relation(fields: [analystId], references: [id])
  role      String  @default("admin") @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, analystId])
  @@index([userId])
  @@index([analystId])
}

enum UserChatKind {
  scout
  study
  interview
  misc
}

model UserChat {
  id              Int          @id @default(autoincrement())
  token           String       @unique @db.VarChar(64)
  userId          Int
  user            User         @relation(fields: [userId], references: [id])
  title           String       @db.VarChar(255)
  kind            UserChatKind
  backgroundToken String?      @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  personas         Persona[]
  analyst          Analyst?
  analystInterview AnalystInterview?
  featuredStudy    FeaturedStudy?
  statistics       ChatStatistics[]
  messages         ChatMessage[]
}

enum MessageRole {
  system
  user
  assistant
  data
}

model ChatMessage {
  id         Int         @id @default(autoincrement())
  messageId  String      @unique @db.VarChar(64)
  userChatId Int
  userChat   UserChat    @relation(fields: [userChatId], references: [id])
  role       MessageRole
  content    String      @db.Text
  parts      Json
  extra      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userChatId, id]) // 通过自增 ID 排序
}

enum ChatStatisticsDimension {
  tokens
  duration
  steps
  personas
  interviews
}

model ChatStatistics {
  id         Int                     @id @default(autoincrement())
  userChatId Int
  userChat   UserChat                @relation(fields: [userChatId], references: [id])
  dimension  ChatStatisticsDimension
  value      Int                     @default(0)
  extra      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PaymentStatus {
  pending
  succeeded
  failed
}

enum Currency {
  CNY
  USD
}

model PaymentRecord {
  id            Int           @id @default(autoincrement())
  userId        Int
  user          User          @relation(fields: [userId], references: [id])
  orderNo       String        @unique @db.VarChar(64)
  amount        Float
  currency      Currency
  status        PaymentStatus
  paymentMethod String        @db.VarChar(64)
  charge        Json
  chargeId      String        @unique @db.VarChar(255)
  credential    Json
  description   String        @db.VarChar(255)
  paidAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentLines PaymentLine[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(64)
  price       Float
  description String   @db.VarChar(255)
  currency    Currency
  extra       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentLines PaymentLine[]

  @@unique([name, currency])
}

model PaymentLine {
  id              Int           @id @default(autoincrement())
  paymentRecordId Int
  paymentRecord   PaymentRecord @relation(fields: [paymentRecordId], references: [id])
  productId       Int
  product         Product       @relation(fields: [productId], references: [id])
  productName     String        @db.VarChar(64)
  description     String        @db.VarChar(255)
  quantity        Int
  price           Float
  currency        Currency      @default(CNY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([paymentRecordId, productId])
}

model UserTokens {
  id      Int  @id @default(autoincrement())
  userId  Int  @unique
  user    User @relation(fields: [userId], references: [id])
  balance Int  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserTokensLogVerb {
  recharge
  consume
  daily
  gift
  signup
}

enum UserTokensLogResourceType {
  StudyUserChat
  ScoutUserChat
  PaymentRecord
}

model UserTokensLog {
  id           Int                        @id @default(autoincrement())
  userId       Int
  user         User                       @relation(fields: [userId], references: [id])
  value        Int
  verb         UserTokensLogVerb
  resourceType UserTokensLogResourceType?
  resourceId   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, verb])
  @@index([userId, verb, resourceType, resourceId])
}

model SystemConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(255)
  value Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
